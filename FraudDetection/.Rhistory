# Load mtcars dataset
data(mtcars)
# Assign dataset to an object
cars_data <- mtcars
# -----------------------------
# 3. Examine Dataset Contents
# -----------------------------
# View first 6 rows
head(cars_data)
# View last 6 rows
tail(cars_data)
# Structure of dataset
str(cars_data)
# Summary statistics
summary(cars_data)
# Dimensions (rows, columns)
dim(cars_data)
# Column names
colnames(cars_data)
# -----------------------------
# 4. Manipulate Dataset
# -----------------------------
# Access a column (Miles Per Gallon)
cars_data$mpg
# Add a new column (Fuel Efficiency category)
cars_data$Efficiency <- ifelse(cars_data$mpg >= 20,
"High",
"Low")
# Filter cars with high efficiency
efficient_cars <- subset(cars_data, mpg >= 20)
# Sort cars by mileage
sorted_cars <- cars_data[order(cars_data$mpg), ]
# Rename a column
colnames(cars_data)[1] <- "Mileage"
# Remove a column (example: carb)
cars_data$carb <- NULL
# -----------------------------
# 5. Save Dataset
# -----------------------------
# Save dataset as CSV file
write.csv(cars_data,
"mtcars_updated.csv",
row.names = FALSE)
# Save R object
save(cars_data, file = "cars_data.RData")
# Load saved R object
load("cars_data.RData")
# -----------------------------
# 6. Check Workspace
# -----------------------------
ls()
# -----------------------------
# 7. Exit R Environment
# -----------------------------
q()
View(efficient_cars)
source("~/R lab/rdemo.R")
View(cars_data)
